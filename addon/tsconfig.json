{
    "compilerOptions": {
        "target": "es2020",
        "module": "es2020",
        "moduleResolution": "node",
        "declaration": false,
        "sourceMap": true,
        "strict": true,
        "noImplicitAny": true,
        "noImplicitReturns": false,
        "noImplicitUseStrict": false,
        "outDir": "lib",
        "rootDir": "scripts",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["scripts/**/*"],
    "exclude": ["lib", "node_modules"],
    "compileOnSave": false
}
